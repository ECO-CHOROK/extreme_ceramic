<odoo>
    <data noupdate="1">
        <record id="seq_reservation_cash_in" model="ir.sequence">
            <field name="name">Encaissement Reservation</field>
            <field name="code">reservation.cash.in</field>
            <field name="prefix">CIN/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_sale_customer_reservation" model="ir.sequence">
            <field name="name">Reservation Devis</field>
            <field name="code">sale.customer.reservation</field>
            <field name="prefix">RSV/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
