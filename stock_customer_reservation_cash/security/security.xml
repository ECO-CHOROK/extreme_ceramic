<odoo>
    <data>
        <record id="group_reservation_cash_user" model="res.groups">
            <field name="name">Reservation Cash User</field>
            <field name="implied_ids" eval="[(4, ref('stock.group_stock_user')), (4, ref('sales_team.group_sale_salesman'))]"/>
        </record>

        <record id="group_reservation_cash_manager" model="res.groups">
            <field name="name">Reservation Cash Manager</field>
            <field name="implied_ids" eval="[(4, ref('stock.group_stock_manager')), (4, ref('account.group_account_invoice')), (4, ref('sales_team.group_sale_manager')), (4, ref('stock_customer_reservation_cash.group_reservation_cash_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
