<odoo>
    <data noupdate="1">
        <record id="rule_cash_in_company" model="ir.rule">
            <field name="name">Cash in company</field>
            <field name="model_id" ref="model_reservation_cash_in"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('stock_customer_reservation_cash.group_reservation_cash_user'))]"/>
        </record>

        <record id="rule_payment_mode_company" model="ir.rule">
            <field name="name">Payment mode company</field>
            <field name="model_id" ref="model_reservation_payment_mode"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('stock_customer_reservation_cash.group_reservation_cash_user'))]"/>
        </record>

        <record id="rule_sale_customer_reservation_company" model="ir.rule">
            <field name="name">Sale reservation company</field>
            <field name="model_id" ref="model_sale_customer_reservation"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('stock_customer_reservation_cash.group_reservation_cash_user'))]"/>
        </record>
    </data>
</odoo>
