<odoo>
    <record id="view_warehouse_form_inherit_reservation_cash" model="ir.ui.view">
        <field name="name">stock.warehouse.form.reservation.cash</field>
        <field name="model">stock.warehouse</field>
        <field name="inherit_id" ref="stock.view_warehouse"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group" position="inside">
                <group string="Customer Reservation" groups="stock_customer_reservation_cash.group_reservation_cash_manager">
                    <field name="reservation_parent_location_id"/>
                    <field name="reservation_internal_picking_type_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
