<odoo>
    <record id="view_delivery_contact_wizard_form" model="ir.ui.view">
        <field name="name">delivery.contact.wizard.form</field>
        <field name="model">delivery.contact.wizard</field>
        <field name="arch" type="xml">
            <form string="Delivery Validation">
                <group>
                    <field name="invoice_to_other"/>
                    <field name="contact_id" invisible="not invoice_to_other"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
