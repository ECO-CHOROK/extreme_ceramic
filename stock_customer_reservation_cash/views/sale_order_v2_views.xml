<odoo>
    <record id="view_order_form_inherit_reservation_v2" model="ir.ui.view">
        <field name="name">sale.order.form.reservation.v2</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@id='action_confirm']" position="before">
                <button name="action_reserve_quotation" string="Reserve" type="object" class="btn-secondary" invisible="state not in ('draft', 'sent') or reservation_state == 'reserved'"/>
                <button name="action_open_cash_in_wizard" string="Collect Cash" type="object" class="btn-primary" invisible="state not in ('draft', 'sent') or reservation_state != 'reserved'"/>
                <button name="action_cancel_reservation" string="Cancel Reservation" type="object" class="btn-secondary" invisible="reservation_state != 'reserved'"/>
            </xpath>
            <xpath expr="//sheet//div[hasclass('oe_title')]/h1" position="before">
                <field name="reservation_state"
                       widget="badge"
                       class="oe_inline rounded-pill"
                       readonly="1"
                       decoration-success="reservation_state == 'reserved'"
                       decoration-danger="reservation_state == 'cancelled'"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_reservation" type="object" class="oe_stat_button" icon="fa-archive" invisible="reservation_count == 0">
                    <field name="reservation_count" widget="statinfo" string="Reservation"/>
                </button>
                <button name="action_view_reservation_transfers" type="object" class="oe_stat_button" icon="fa-exchange" invisible="reservation_transfer_count == 0">
                    <field name="reservation_transfer_count" widget="statinfo" string="Transferts de réservation"/>
                </button>
                <button name="action_view_cash_in" type="object" class="oe_stat_button" icon="fa-money" invisible="reservation_count == 0">
                    <field name="cash_in_ratio_display" widget="statinfo" string="Collected / Quotation"/>
                </button>
            </xpath>
            <xpath expr="//field[@name='warehouse_id']" position="after">
                <field name="warehouse_view_location_id" invisible="1"/>
                <field name="reservation_source_location_id"
                       domain="[('usage', '=', 'internal'), ('company_id', '=', company_id), ('id', 'child_of', warehouse_view_location_id)]"
                       readonly="reservation_state == 'reserved'"/>
            </xpath>
            <xpath expr="//group[@name='sale_info']" position="inside">
                <field name="reservation_id" readonly="1"/>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <div class="alert border border-info bg-info-subtle text-info fw-semibold mt-2 mb-2"
                     role="alert"
                     invisible="not reservation_credit_alert">
                    <span class="fa fa-exclamation-triangle me-2"/>
                    <field name="reservation_credit_alert_message" readonly="1" nolabel="1"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
