<odoo>
    <record id="view_sale_cancel_reservation_cash_wizard_form" model="ir.ui.view">
        <field name="name">sale.cancel.reservation.cash.wizard.form</field>
        <field name="model">sale.cancel.reservation.cash.wizard</field>
        <field name="arch" type="xml">
            <form string="Cancellation and Cash Collections">
                <group>
                    <field name="order_ids" widget="many2many_tags" readonly="1"/>
                    <field name="reservation_ids" widget="many2many_tags" readonly="1"/>
                    <field name="cash_in_ids" widget="many2many_tags" readonly="1"/>
                </group>
                <group>
                    <field name="decision"/>
                    <field name="target_reservation_id" invisible="decision != 'relink'"/>
                    <field name="target_sale_order_id" invisible="decision != 'relink'"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
