<odoo>
    <record id="view_reservation_payment_mode_tree" model="ir.ui.view">
        <field name="name">reservation.payment.mode.tree</field>
        <field name="model">reservation.payment.mode</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="company_id"/>
                <field name="journal_id"/>
                <field name="clearing_policy"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_reservation_payment_mode_form" model="ir.ui.view">
        <field name="name">reservation.payment.mode.form</field>
        <field name="model">reservation.payment.mode</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="journal_id"/>
                            <field name="inbound_payment_method_line_id"/>
                            <field name="is_cheque_lcn"/>
                            <field name="clearing_policy"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_reservation_payment_mode" model="ir.actions.act_window">
        <field name="name">Reservation Payment Modes</field>
        <field name="res_model">reservation.payment.mode</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
